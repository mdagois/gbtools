; Declare a SOUND command.
; \1 = port A effect
; \2 = port B effect
; \3 = parameters
; \4 = BGM
macro SgbPacket_Sound
db SGB_HEADER_SOUND
db \1, \2, \3, \4
ds 11, SGB_PADDING
endm

