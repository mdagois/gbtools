;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
; Constants
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

def SGB_BYTES_PER_PACKET            equ (16)

def SGB_PADDING                     equ ($00)

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
; Functions
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

; Initialize the SGB device.
macro gbSgbInitializeDevice
    call _gbSgbInitializeDevice
endm

; Send the SGB command at address \1.
macro gbSgbSendCommand
    ld hl, \1
    call _gbSgbSendCommand
endm

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
; PALXX macros
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

; Declare a PAL01 command loading from a .pal file \1 with
; byte offset \2 for the first palette and byte offset \3
; for the second palette.
macro SgbPacket_Pal01
db SGB_HEADER_PAL01
incbin "\1", \2, 8
incbin "\1", \3, 6
db SGB_PADDING
endm

; Declare a PAL23 command loading from a .pal file \1 with
; byte offset \2 for the first palette and byte offset \3
; for the second palette.
macro SgbPacket_Pal23
db SGB_HEADER_PAL23
incbin "\1", \2, 8
incbin "\1", \3, 6
db SGB_PADDING
endm

; Declare a PAL03 command loading from a .pal file \1 with
; byte offset \2 for the first palette and byte offset \3
; for the second palette.
macro SgbPacket_Pal03
db SGB_HEADER_PAL03
incbin "\1", \2, 8
incbin "\1", \3, 6
db SGB_PADDING
endm

; Declare a PAL12 command loading from a .pal file \1 with
; byte offset \2 for the first palette and byte offset \3
; for the second palette.
macro SgbPacket_Pal12
db SGB_HEADER_PAL12
incbin "\1", \2, 8
incbin "\1", \3, 6
db SGB_PADDING
endm

; Declare a PAL_TRN command.
macro SgbPacket_PalTrn
db SGB_HEADER_PAL_TRN
ds 15, SGB_PADDING
endm

; Declare a ATTR_TRN command.
macro SgbPacket_AttrTrn
db SGB_HEADER_ATTR_TRN
ds 15, SGB_PADDING
endm

; PAL_SET flags.
def PAL_SET_FLAG_NONE               equ ($00)
def PAL_SET_FLAG_CANCEL_MASK        equ (1 << 6)
def PAL_SET_FLAG_SET_ATTR           equ (1 << 7)

; Declare a PAL_SET command.
; \1 = palette 0 index (0-511)
; \2 = palette 1 index (0-511)
; \3 = palette 2 index (0-511)
; \4 = palette 3 index (0-511)
; \5 = flags
; \6 = attribute file number (0-44) (PAL_SET_FLAG_SET_ATTR must be in \5)
macro SgbPacket_PalSet
db SGB_HEADER_PAL_SET
dw \1, \2, \3, \4 
db \5 | \6
ds 6, SGB_PADDING
endm

